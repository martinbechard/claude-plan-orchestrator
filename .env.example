# Environment variables for the Claude Plan Orchestrator.
#
# The pipeline loads files in this order (first value wins):
#   1. Real environment variables (export FOO=bar)
#   2. .env.local  -- your private overrides (gitignored)
#   3. .env        -- shared project defaults (may be committed by host project)
#
# Copy this file to .env.local for orchestrator-specific secrets:
#   cp .env.example .env.local
#
# Both .env and .env.local are gitignored by the orchestrator.

# LangSmith tracing (optional, free tier at https://smith.langchain.com)
# LANGSMITH_API_KEY=lsv2_sk_...
# LANGSMITH_WORKSPACE_ID=...    # Required for org-scoped keys (Settings > Workspace ID)

# Slack tokens (alternative to .claude/slack.local.yaml)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
